---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoText from '../assets/logo/logo.svg';

const title = "Cheyla Alencar - Em breve novidades";
const description = "Estamos preparando um novo espaço para você. Em breve novidades sobre fonoaudiologia e autismo.";
---

<Layout title={title} description={description}>
	<main class="h-screen w-full bg-premium-background flex items-center justify-center overflow-hidden relative px-6">
        <!-- Floating Particles Background -->
        <div class="absolute inset-0 z-20 pointer-events-none">
            {Array.from({ length: 30 }).map((_, i) => (
                <div class="particle-dot" style={`--top: ${Math.random() * 100}%; --left: ${Math.random() * 100}%; --size: ${Math.random() * 10 + 3}px; --duration: ${Math.random() * 20 + 10}s; --delay: ${Math.random() * 10}s; --opacity: ${Math.random() * 0.4 + 0.2}`}></div>
            ))}
        </div>
        <div class="absolute inset-0 z-0 pointer-events-none">
            <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-premium-primary/10 rounded-full blur-[100px] animate-pulse"></div>
            <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-premium-secondary/10 rounded-full blur-[120px] animate-pulse"></div>
        </div>

		<div class="text-center z-10 w-full h-full flex flex-col justify-center items-center transform transition-all duration-700 bg-white/30 backdrop-blur-3xl px-4 py-4 md:py-8">
            <div class="mb-4 md:mb-8 flex justify-center scale-75 md:scale-90 lg:scale-100">
                <div class="p-5 md:p-6 bg-premium-primary rounded-[2.5rem] shadow-xl shadow-premium-primary/20 border border-white/10">
                    <Image 
                        src={logoText} 
                        alt="Cheyla Alencar Logo" 
                        class="h-14 md:h-20 w-auto object-contain brightness-0 invert"
                    />
                </div>
            </div>
            
            <div class="mb-6 md:mb-10 flex flex-col items-center">
                <span class="text-premium-primary font-bold uppercase tracking-[0.4em] mb-3 block reveal text-[9px] md:text-xs">Cheyla Alencar - Fonoaudióloga</span>
                
                <h1 class="text-5xl md:text-7xl lg:text-8xl font-black mb-4 text-premium-secondary tracking-tighter leading-[0.85] reveal">
                    Novidades <br /> 
                    <span class="text-premium-primary italic">Em Breve.</span>
                </h1>
                
                <p class="text-slate-600 text-sm md:text-lg lg:text-xl mb-6 md:mb-10 leading-relaxed max-w-xl mx-auto font-medium reveal">
                    Estamos construindo um portal <span class="text-premium-secondary font-bold italic underline decoration-premium-primary underline-offset-4">completo e estruturado</span> para apoiar famílias.
                </p>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-6 justify-center items-center scale-90 lg:scale-100">
                <a href="/vendas" class="btn-premium px-10 py-3 text-sm md:text-base shadow-premium-primary/20">
                    CONHECER O CURSO ATUAL
                </a>
            </div>

            <div class="mt-8 md:mt-12 pt-4 border-t border-slate-200/30 flex flex-col items-center gap-3">
                <span class="text-[9px] md:text-[10px] font-bold text-slate-400 uppercase tracking-[0.3em] reveal text-center">Acompanhe a Jornada</span>
                <a href="https://www.instagram.com/fga.cheylaalencar?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 px-5 py-2 bg-white/40 rounded-full border border-white/20 hover:bg-premium-primary hover:text-white transition-all duration-300 shadow-sm reveal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:rotate-12"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    <span class="text-[11px] md:text-xs font-bold tracking-wide">@CheylaAlencar</span>
                </a>
            </div>
		</div>
	</main>
</Layout>

<style>
    .particle-dot {
        position: absolute;
        top: var(--top);
        left: var(--left);
        width: var(--size);
        height: var(--size);
        background: #FA602E;
        border-radius: 50%;
        animation: float-particle var(--duration) infinite ease-in-out var(--delay);
        opacity: var(--opacity);
        box-shadow: 0 0 10px rgba(250, 96, 46, 0.4);
    }

    @keyframes float-particle {
        0%, 100% { transform: translateY(0) translateX(0) scale(1); }
        33% { transform: translateY(-60px) translateX(30px) scale(1.1); }
        66% { transform: translateY(30px) translateX(-30px) scale(0.9); }
    }

    @keyframes pulse {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.1); }
    }

    .animate-pulse {
        animation: pulse 8s infinite ease-in-out;
    }
</style>
