---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PainPoints from '../components/PainPoints.astro';
import ExpertBio from '../components/ExpertBio.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQ from '../components/FAQ.astro';
import WhatYouLearn from '../components/WhatYouLearn.astro';
import Expectation from '../components/Expectation.astro';

import { Image } from 'astro:assets';
import logoText from '../assets/logo/logo.svg';

const title = "Curso prático para estimular a comunicação do seu filho | Cheyla Alencar";
const description = "Aprenda a estimular a comunicação do seu filho de forma prática e real com Cheyla Alencar.";
---

<Layout title={title} description={description}>
	<main class="overflow-x-hidden bg-premium-background">
		<!-- Navigation (Floating) -->
		<nav id="main-nav" class="fixed top-4 left-1/2 -translate-x-1/2 w-[90%] md:w-3/4 max-w-7xl z-50 px-8 py-4 transition-all duration-500 ease-in-out rounded-full">
			<div class="container mx-auto flex justify-center md:justify-between items-center gap-4">
				<a href="/" class="block hover:opacity-80 transition-all duration-300 transform hover:scale-105 shrink-0">
					<Image 
						src={logoText} 
						alt="Cheyla Alencar Logo" 
						id="nav-logo"
						class="h-8 md:h-10 w-auto object-contain transition-all duration-300"
					/>
				</a>
				<a href="#oferta" id="nav-btn" class="hidden md:block px-6 py-2 bg-white/90 backdrop-blur-md border border-transparent rounded-full text-xs font-extrabold text-premium-secondary hover:bg-premium-secondary hover:text-white transition-all shadow-lg shrink-0">
					QUERO ME INSCREVER
				</a>
			</div>
		</nav>

		<Hero />
		
		<div class="h-px w-full bg-gradient-to-r from-transparent via-[#387798]/20 to-transparent"></div>
		
		<WhatYouLearn />
		
		<Expectation />

		<div class="h-px w-full bg-gradient-to-r from-transparent via-[#387798]/20 to-transparent"></div>

		<ExpertBio />
		
		<!-- Floating Testimonial/Social Proof Bar -->
		<section class="py-12 bg-premium-soft text-premium-secondary overflow-hidden whitespace-nowrap border-y border-[#387798]/5">
			<div class="flex gap-12 animate-scroll font-bold text-xl md:text-2xl tracking-widest opacity-60 uppercase">
				<span>Comunicação com Amor • </span>
				<span>Conexão que Transforma • </span>
				<span>Evolução no Ritmo Certo • </span>
				<span>Estratégia que Funciona • </span>
				<span>Comunicação com Amor • </span>
				<span>Conexão que Transforma • </span>
				<span>Evolução no Ritmo Certo • </span>
				<span>Estratégia que Funciona • </span>
			</div>
		</section>

		<PricingCard />
		
		<FAQ />

		<!-- Footer -->
		<footer class="py-20 bg-[#E8F1F3]/30 border-t border-[#387798]/5 text-center text-slate-400 text-sm">
			<div class="flex justify-center mb-8">
				<Image 
					src={logoText} 
					alt="Cheyla Alencar Logo" 
					class="h-12 md:h-16 w-auto opacity-80 grayscale brightness-50"
				/>
			</div>
			<div class="container mx-auto px-6">
				<p class="mb-4 font-bold text-premium-secondary/60 uppercase tracking-widest">Cheyla Alencar - Estratégia e Conexão © 2026</p>
				<p class="max-w-xl mx-auto mb-8 leading-relaxed text-base">
					Seu filho não precisa de mais tempo.<br>Ele precisa da estratégia certa, e você pode ser essa ponte.
				</p>
				<div class="flex flex-col md:flex-row justify-center items-center gap-6 md:gap-12 mb-12">
					<a href="https://www.instagram.com/fga.cheylaalencar?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-premium-secondary font-bold hover:text-premium-primary transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
						@CheylaAlencar
					</a>
					<div class="flex gap-6">
						<a href="#" class="hover:text-premium-primary transition-colors">Termos de Uso</a>
						<a href="#" class="hover:text-premium-primary transition-colors">Privacidade</a>
					</div>
				</div>
				<div class="text-[10px] opacity-100 tracking-[0.2em] font-bold">
					CRIADO COM DEDICAÇÃO POR <a href="https://www.sitesalphacode.com.br/solucoes" target="_blank" rel="noopener noreferrer">SITES ALPHA CODE</a>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<script>
	const nav = document.getElementById('main-nav');
	const logo = document.getElementById('nav-logo');
	const btn = document.getElementById('nav-btn');

	window.addEventListener('scroll', () => {
		if (window.scrollY > 50) {
			nav?.classList.add('bg-[#FA602E]/90', 'backdrop-blur-xl', 'shadow-2xl', 'py-3', 'border', 'border-white/20');
			nav?.classList.remove('py-4');
			logo?.classList.add('brightness-0', 'invert'); 
			btn?.classList.add('scale-90', 'opacity-90');
		} else {
			nav?.classList.remove('bg-[#FA602E]/90', 'backdrop-blur-xl', 'shadow-2xl', 'py-3', 'border', 'border-white/20');
			nav?.classList.add('py-4');
			logo?.classList.remove('brightness-0', 'invert');
			btn?.classList.remove('scale-90', 'opacity-90');
		}
	});
</script>

<style>
	.animate-scroll {
		animation: scroll 30s linear infinite;
	}

	@keyframes scroll {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
</style>
